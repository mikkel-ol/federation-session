{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "es2022",
    "lib": ["dom", "es2022"],
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/host/runtime-browser.ts"]
}
